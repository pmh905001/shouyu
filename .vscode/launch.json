{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch shouyu main.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/.env",
            "python": "${workspaceFolder}/venv310/Scripts/python.exe",
            "args": [],
            "justMyCode": true
        },
        {
            "name": "Launch shouyu main.py (External Terminal)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "externalTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/.env",
            "python": "${workspaceFolder}/venv310/Scripts/python.exe",
            "args": [],
            "justMyCode": true
        }
    ]
}